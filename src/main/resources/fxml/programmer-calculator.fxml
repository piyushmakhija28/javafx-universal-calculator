<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="8"
      prefWidth="680" prefHeight="560"
      style="-fx-padding: 16; -fx-background-color: #1e1e1e;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.ProgrammerCalculatorController">

    <!-- Display -->
    <TextField fx:id="display"
               styleClass="display-field"
               editable="false"
               alignment="CENTER_RIGHT"
               style="-fx-font-size: 24px; -fx-background-color: #1a1a1a; -fx-text-fill: #ffffff;
                      -fx-font-family: 'Consolas', monospace; -fx-border-color: #404040;
                      -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;
                      -fx-padding: 8 12 8 12;"/>

    <!-- Base Selector: HEX / DEC / OCT / BIN -->
    <HBox spacing="8">
        <RadioButton fx:id="rbHex" text="HEX"
                     style="-fx-text-fill: #e0e0e0;" onAction="#onBaseChange">
            <toggleGroup><ToggleGroup fx:id="baseToggle"/></toggleGroup>
        </RadioButton>
        <RadioButton fx:id="rbDec" text="DEC" toggleGroup="$baseToggle" selected="true"
                     style="-fx-text-fill: #e0e0e0;" onAction="#onBaseChange"/>
        <RadioButton fx:id="rbOct" text="OCT" toggleGroup="$baseToggle"
                     style="-fx-text-fill: #e0e0e0;" onAction="#onBaseChange"/>
        <RadioButton fx:id="rbBin" text="BIN" toggleGroup="$baseToggle"
                     style="-fx-text-fill: #e0e0e0;" onAction="#onBaseChange"/>
    </HBox>

    <!-- Bit Display Label -->
    <Label fx:id="bitDisplay" text="0000 0000 0000 0000"
           style="-fx-text-fill: #4a90d9; -fx-font-family: 'Consolas', monospace; -fx-font-size: 12px;"/>

    <!-- Button Grid: 5 rows × 6 columns -->
    <GridPane styleClass="calculator-root" hgap="5" vgap="5" VBox.vgrow="ALWAYS">

        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="16.66"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="16.66"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="16.66"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="16.66"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="16.66"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="16.66"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints vgrow="ALWAYS" percentHeight="20"/>
            <RowConstraints vgrow="ALWAYS" percentHeight="20"/>
            <RowConstraints vgrow="ALWAYS" percentHeight="20"/>
            <RowConstraints vgrow="ALWAYS" percentHeight="20"/>
            <RowConstraints vgrow="ALWAYS" percentHeight="20"/>
        </rowConstraints>

        <!-- Row 0: Bitwise operations -->
        <Button text="AND"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button text="OR"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button text="XOR"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Button text="NOT"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <Button text="SHL"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
        <Button text="SHR"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise" GridPane.columnIndex="5" GridPane.rowIndex="0"/>

        <!-- Row 1: Hex digits A-F + MOD -->
        <Button fx:id="btnA" text="A"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onHexDigit" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button fx:id="btnB" text="B"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onHexDigit" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button fx:id="btnC" text="C"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onHexDigit" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Button fx:id="btnD" text="D"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onHexDigit" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        <Button fx:id="btnE" text="E"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onHexDigit" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
        <Button fx:id="btnF" text="F"   styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onHexDigit" GridPane.columnIndex="5" GridPane.rowIndex="1"/>

        <!-- Row 2: 7 8 9 ÷ MOD C -->
        <Button text="7"    styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Button text="8"    styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Button text="9"    styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <Button text="÷"    styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onOperator" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
        <Button text="MOD"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onBitwise"  GridPane.columnIndex="4" GridPane.rowIndex="2"/>
        <Button text="C"    styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onClear"    GridPane.columnIndex="5" GridPane.rowIndex="2"/>

        <!-- Row 3: 4 5 6 × + - -->
        <Button text="4"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Button text="5"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Button text="6"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="2" GridPane.rowIndex="3"/>
        <Button text="×"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onOperator" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
        <Button text="+"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onOperator" GridPane.columnIndex="4" GridPane.rowIndex="3"/>
        <Button text="−"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onOperator" GridPane.columnIndex="5" GridPane.rowIndex="3"/>

        <!-- Row 4: 1 2 3 0 CE = -->
        <Button text="1"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <Button text="2"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <Button text="3"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="2" GridPane.rowIndex="4"/>
        <Button text="0"  styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onDigit"    GridPane.columnIndex="3" GridPane.rowIndex="4"/>
        <Button text="CE" styleClass="calc-button" maxWidth="Infinity" maxHeight="Infinity" onAction="#onClearEntry" GridPane.columnIndex="4" GridPane.rowIndex="4"/>
        <Button fx:id="btnEquals" text="=" styleClass="calc-button button-accent" maxWidth="Infinity" maxHeight="Infinity" onAction="#onEquals" GridPane.columnIndex="5" GridPane.rowIndex="4"/>

    </GridPane>
</VBox>
