<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="16"
      style="-fx-padding: 32; -fx-background-color: #1e1e1e; -fx-alignment: top-center;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.EMICalculatorController">

    <Label text="EMI / Loan Calculator"
           style="-fx-text-fill: #e0e0e0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="200" prefWidth="220"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Principal Amount (&#8377;)" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="fieldPrincipal" promptText="e.g. 500000" styleClass="display-field"
                   style="-fx-font-size: 14px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0;
                          -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 10 6 10;"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Annual Interest Rate (%)" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="fieldRate" promptText="e.g. 8.5" styleClass="display-field"
                   style="-fx-font-size: 14px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0;
                          -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 10 6 10;"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Tenure (Months)" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="fieldTenure" promptText="e.g. 240" styleClass="display-field"
                   style="-fx-font-size: 14px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0;
                          -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 10 6 10;"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <Button fx:id="btnCalculate" text="Calculate EMI" styleClass="calc-button button-accent"
            onAction="#onCalculate"
            style="-fx-min-width: 160px; -fx-alignment: center;"/>

    <Separator style="-fx-background-color: #404040;"/>

    <!-- Single result area — displays full service output string directly -->
    <Label text="Result" style="-fx-text-fill: #9e9e9e; -fx-font-size: 13px;"/>
    <TextArea fx:id="resultArea"
              editable="false"
              wrapText="true"
              prefHeight="80"
              styleClass="result-area"
              style="-fx-control-inner-background: #1a1a1a; -fx-text-fill: #e0e0e0;
                     -fx-font-size: 14px; -fx-border-color: #404040; -fx-border-width: 1;
                     -fx-border-radius: 4; -fx-background-radius: 4;"/>

</VBox>
