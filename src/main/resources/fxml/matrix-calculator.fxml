<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="12"
      style="-fx-padding: 16; -fx-background-color: #1e1e1e;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.MatrixCalculatorController">

    <Label text="Matrix Calculator"
           style="-fx-text-fill: #e0e0e0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- Size Toggle -->
    <fx:define>
        <ToggleGroup fx:id="sizeToggle"/>
    </fx:define>
    <HBox spacing="16">
        <Label text="Size:" style="-fx-text-fill: #9e9e9e;"/>
        <RadioButton fx:id="rb2x2" text="2×2" toggleGroup="$sizeToggle" selected="true"
                     style="-fx-text-fill: #e0e0e0;" onAction="#onSizeChange"/>
        <RadioButton fx:id="rb3x3" text="3×3" toggleGroup="$sizeToggle"
                     style="-fx-text-fill: #e0e0e0;" onAction="#onSizeChange"/>
    </HBox>

    <!-- Matrix Inputs -->
    <HBox spacing="24">
        <!-- Matrix A -->
        <VBox spacing="6">
            <Label text="Matrix A" style="-fx-text-fill: #4a90d9; -fx-font-weight: bold;"/>
            <GridPane fx:id="gridA" hgap="4" vgap="4">
                <columnConstraints>
                    <ColumnConstraints minWidth="60" prefWidth="70"/>
                    <ColumnConstraints minWidth="60" prefWidth="70"/>
                    <ColumnConstraints fx:id="colA3" minWidth="60" prefWidth="70" visible="false" managed="false"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="32"/>
                    <RowConstraints minHeight="32"/>
                    <RowConstraints fx:id="rowA3" minHeight="32" managed="false"/>
                </rowConstraints>
                <TextField fx:id="a00" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="a01" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="a02" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="a10" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="a11" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <TextField fx:id="a12" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="a20" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="a21" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <TextField fx:id="a22" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            </GridPane>
        </VBox>

        <!-- Matrix B -->
        <VBox spacing="6">
            <Label text="Matrix B" style="-fx-text-fill: #4a90d9; -fx-font-weight: bold;"/>
            <GridPane fx:id="gridB" hgap="4" vgap="4">
                <columnConstraints>
                    <ColumnConstraints minWidth="60" prefWidth="70"/>
                    <ColumnConstraints minWidth="60" prefWidth="70"/>
                    <ColumnConstraints fx:id="colB3" minWidth="60" prefWidth="70" visible="false" managed="false"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="32"/>
                    <RowConstraints minHeight="32"/>
                    <RowConstraints fx:id="rowB3" minHeight="32" managed="false"/>
                </rowConstraints>
                <TextField fx:id="b00" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="b01" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="b02" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="b10" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="b11" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <TextField fx:id="b12" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <TextField fx:id="b20" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="b21" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <TextField fx:id="b22" text="0" styleClass="display-field" maxWidth="Infinity" maxHeight="Infinity"
                           style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-radius: 3; -fx-padding: 4 6 4 6;"
                           GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            </GridPane>
        </VBox>
    </HBox>

    <!-- Operation Buttons -->
    <HBox spacing="8">
        <Button text="Add"         styleClass="calc-button" onAction="#onOperation"/>
        <Button text="Subtract"    styleClass="calc-button" onAction="#onOperation"/>
        <Button text="Multiply"    styleClass="calc-button" onAction="#onOperation"/>
        <Button text="Transpose A" styleClass="calc-button" onAction="#onOperation"/>
        <Button text="Det A"       styleClass="calc-button" onAction="#onOperation"/>
    </HBox>

    <Separator style="-fx-background-color: #404040;"/>

    <Label text="Result" style="-fx-text-fill: #9e9e9e;"/>
    <TextArea fx:id="resultArea" editable="false"
              style="-fx-background-color: #1a1a1a; -fx-text-fill: #ffffff; -fx-font-family: 'Consolas', monospace;
                     -fx-font-size: 13px; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"
              prefRowCount="4"/>

</VBox>
