<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="16"
      style="-fx-padding: 32; -fx-background-color: #1e1e1e; -fx-alignment: top-center;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.AgeCalculatorController">

    <Label text="Age Calculator"
           style="-fx-text-fill: #e0e0e0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="160" prefWidth="200"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Date of Birth" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <DatePicker fx:id="pickerDOB" promptText="Select DOB"
                    style="-fx-background-color: #252525; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"
                    GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Target Date (or today)" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <DatePicker fx:id="pickerTarget" promptText="Today (default)"
                    style="-fx-background-color: #252525; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"
                    GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <Button fx:id="btnCalculate" text="Calculate Age" styleClass="calc-button button-accent"
            onAction="#onCalculate" style="-fx-min-width: 160px;"/>

    <Separator style="-fx-background-color: #404040;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="160"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Years" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="labelYears" text="—" styleClass="result-label"
               style="-fx-text-fill: #4a90d9; -fx-font-size: 22px; -fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Months" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="labelMonths" text="—" styleClass="result-label"
               style="-fx-text-fill: #ffffff; -fx-font-size: 16px;"
               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Days" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="labelDays" text="—" styleClass="result-label"
               style="-fx-text-fill: #ffffff; -fx-font-size: 16px;"
               GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Total Days" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label fx:id="labelTotalDays" text="—" styleClass="result-label"
               style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;"
               GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>

</VBox>
