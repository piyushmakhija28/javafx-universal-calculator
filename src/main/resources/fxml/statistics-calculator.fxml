<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="12"
      style="-fx-padding: 24; -fx-background-color: #1e1e1e;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.StatisticsCalculatorController">

    <Label text="Statistics Calculator"
           style="-fx-text-fill: #e0e0e0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Label text="Enter comma-separated numbers:" style="-fx-text-fill: #9e9e9e;"/>
    <TextArea fx:id="inputArea"
              promptText="e.g. 10, 20, 30, 40, 50"
              prefRowCount="3"
              wrapText="true"
              style="-fx-background-color: #252525; -fx-text-fill: #e0e0e0; -fx-font-size: 14px;
                     -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"/>

    <Button fx:id="btnCalculate" text="Calculate Statistics" styleClass="calc-button button-accent"
            onAction="#onCalculate" style="-fx-min-width: 180px;"/>

    <Separator style="-fx-background-color: #404040;"/>

    <GridPane hgap="24" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="140"/>
            <ColumnConstraints minWidth="140"/>
            <ColumnConstraints minWidth="140"/>
            <ColumnConstraints minWidth="140"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="52"/>
            <RowConstraints minHeight="52"/>
        </rowConstraints>

        <!-- Row 0 -->
        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="Mean" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelMean" text="—" styleClass="result-label"
                   style="-fx-text-fill: #4a90d9; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="Median" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelMedian" text="—" styleClass="result-label"
                   style="-fx-text-fill: #4a90d9; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0">
            <Label text="Mode" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelMode" text="—" styleClass="result-label"
                   style="-fx-text-fill: #4a90d9; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0">
            <Label text="Count" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelCount" text="—" styleClass="result-label"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- Row 1 -->
        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label text="Std Deviation" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelStdDev" text="—" styleClass="result-label"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label text="Variance" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelVariance" text="—" styleClass="result-label"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox GridPane.columnIndex="2" GridPane.rowIndex="1">
            <Label text="Min" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelMin" text="—" styleClass="result-label"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
        <VBox GridPane.columnIndex="3" GridPane.rowIndex="1">
            <Label text="Max" style="-fx-text-fill: #9e9e9e; -fx-font-size: 12px;"/>
            <Label fx:id="labelMax" text="—" styleClass="result-label"
                   style="-fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>

</VBox>
