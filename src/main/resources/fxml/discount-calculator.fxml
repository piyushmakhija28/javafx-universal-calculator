<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="16"
      style="-fx-padding: 32; -fx-background-color: #1e1e1e; -fx-alignment: top-center;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.DiscountCalculatorController">

    <Label text="Discount Calculator"
           style="-fx-text-fill: #e0e0e0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="160" prefWidth="200"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Original Price" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="fieldOriginalPrice" promptText="e.g. 1200" styleClass="display-field"
                   style="-fx-font-size: 14px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0;
                          -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 10 6 10;"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Discount (%)" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="fieldDiscount" promptText="e.g. 20" styleClass="display-field"
                   style="-fx-font-size: 14px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0;
                          -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 10 6 10;"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <Button fx:id="btnCalculate" text="Calculate Discount" styleClass="calc-button button-accent"
            onAction="#onCalculate" style="-fx-min-width: 160px;"/>

    <Separator style="-fx-background-color: #404040;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="160"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Final Price" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="labelFinalPrice" text="—" styleClass="result-label"
               style="-fx-text-fill: #2ecc71; -fx-font-size: 22px; -fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Amount Saved" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="labelAmountSaved" text="—" styleClass="result-label"
               style="-fx-text-fill: #4a90d9; -fx-font-size: 18px; -fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

</VBox>
