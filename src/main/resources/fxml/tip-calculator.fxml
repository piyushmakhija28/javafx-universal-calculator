<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SpinnerValueFactory?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="calculator-root"
      spacing="16"
      style="-fx-padding: 32; -fx-background-color: #1e1e1e; -fx-alignment: top-center;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.techdeveloper.calculator.controller.TipCalculatorController">

    <Label text="Tip Calculator"
           style="-fx-text-fill: #e0e0e0; -fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="160" prefWidth="200"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="48"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Bill Amount" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="fieldBill" promptText="e.g. 500" styleClass="display-field"
                   style="-fx-font-size: 14px; -fx-background-color: #252525; -fx-text-fill: #e0e0e0;
                          -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 10 6 10;"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Tip Percentage" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <HBox spacing="8">
                <Slider fx:id="sliderTip" min="0" max="30" value="15" HBox.hgrow="ALWAYS"
                        showTickLabels="true" showTickMarks="true" majorTickUnit="10"
                        style="-fx-pref-width: 200px;"/>
                <Label fx:id="labelTipPercent" text="15%"
                       style="-fx-text-fill: #4a90d9; -fx-font-size: 14px; -fx-font-weight: bold; -fx-min-width: 40px;"/>
            </HBox>
        </VBox>

        <Label text="Split Between" style="-fx-text-fill: #9e9e9e;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Spinner fx:id="spinnerSplit" min="1" max="10" initialValue="1"
                 style="-fx-background-color: #252525; -fx-border-color: #404040; -fx-border-width: 1; -fx-border-radius: 4; -fx-background-radius: 4;"
                 GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <Button fx:id="btnCalculate" text="Calculate" styleClass="calc-button button-accent"
            onAction="#onCalculate" style="-fx-min-width: 160px;"/>

    <Separator style="-fx-background-color: #404040;"/>

    <GridPane hgap="16" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="160"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
            <RowConstraints minHeight="36"/>
        </rowConstraints>

        <Label text="Tip Amount" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="labelTipAmount" text="—" styleClass="result-label"
               style="-fx-text-fill: #4a90d9; -fx-font-size: 18px; -fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Total Bill" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="labelTotal" text="—" styleClass="result-label"
               style="-fx-text-fill: #ffffff; -fx-font-size: 16px;"
               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Per Person" style="-fx-text-fill: #9e9e9e; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="labelPerPerson" text="—" styleClass="result-label"
               style="-fx-text-fill: #2ecc71; -fx-font-size: 18px; -fx-font-weight: bold;"
               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

</VBox>
